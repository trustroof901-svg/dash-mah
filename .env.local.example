# ---- Shopify (server-side only, NEVER commit real values) ----
# Your store domain, e.g. gv7tc1-4b.myshopify.com
SHOPIFY_STORE_DOMAIN=gv7tc1-4b.myshopify.com
# Admin API access token (shpat_...). ROTATE the one you shared in chat!
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shopify Admin API version
SHOPIFY_API_VERSION=2024-10

# ---- Supabase ----
# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role key: server-only, used by the sync job. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Sync security ----
# A random secret so only Vercel Cron (and you) can trigger /api/sync.
# Generate one: any long random string.
CRON_SECRET=change-me-to-a-long-random-string
