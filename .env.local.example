# ---- Shopify (server-side only, NEVER commit real values) ----
# Your store domain, e.g. gv7tc1-4b.myshopify.com
SHOPIFY_STORE_DOMAIN=gv7tc1-4b.myshopify.com
# Admin API access token (shpat_...). ROTATE the one you shared in chat!
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shopify Admin API version
SHOPIFY_API_VERSION=2024-10

# ---- Supabase ----
# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role key: server-only, used by the sync job. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Sync security ----
# A random secret so only Vercel Cron (and you) can trigger /api/sync.
# Generate one: any long random string.
CRON_SECRET=change-me-to-a-long-random-string

# ---- Sample Inquiries dashboard (optional "link out" navbar tab) ----
# URL of the separate Sample Inquiries dashboard. When set, a "Sample
# Inquiries" tab appears in the sidebar and opens this URL in a new tab.
# e.g. https://your-inquiries-app.vercel.app  (or http://localhost:3000 locally)
NEXT_PUBLIC_INQUIRIES_URL=

# ---- Call-center login ----
# Password for the /team login. After logging in, that browser shows only
# Abandoned Carts, Create Order and Sample Inquiries. The normal dashboard
# (no login) is unaffected. Change this from the default before sharing.
NEXT_PUBLIC_CC_PASSWORD=callcenter

# ---- Offline sales (Odoo CDS Analytics API) ----
# Live Odoo server URL and the company Analytics Token.
# The /api/sync-odoo job pulls "استهلاكي" invoices into offline_sales.
ODOO_BASE_URL=https://your-odoo-server.com
ODOO_API_KEY=your-analytics-token
# Which customer name to keep (the API has no customer_type field).
ODOO_CUSTOMER_FILTER=استهلاكي
